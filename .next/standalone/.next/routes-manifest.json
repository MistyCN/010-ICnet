{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/api/discussions/[id]",
      "regex": "^/api/discussions/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/discussions/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/discussions/[id]/poll/vote",
      "regex": "^/api/discussions/([^/]+?)/poll/vote(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/discussions/(?<nxtPid>[^/]+?)/poll/vote(?:/)?$"
    },
    {
      "page": "/api/discussions/[id]/replies",
      "regex": "^/api/discussions/([^/]+?)/replies(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/discussions/(?<nxtPid>[^/]+?)/replies(?:/)?$"
    },
    {
      "page": "/api/uploads/[filename]",
      "regex": "^/api/uploads/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPfilename": "nxtPfilename"
      },
      "namedRegex": "^/api/uploads/(?<nxtPfilename>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/users/[username]",
      "regex": "^/api/users/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPusername": "nxtPusername"
      },
      "namedRegex": "^/api/users/(?<nxtPusername>[^/]+?)(?:/)?$"
    },
    {
      "page": "/discussions/[id]",
      "regex": "^/discussions/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/discussions/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/profile/[username]",
      "regex": "^/profile/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPusername": "nxtPusername"
      },
      "namedRegex": "^/profile/(?<nxtPusername>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/api/auth/register",
      "regex": "^/api/auth/register(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/register(?:/)?$"
    },
    {
      "page": "/api/discussions",
      "regex": "^/api/discussions(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/discussions(?:/)?$"
    },
    {
      "page": "/api/server-status",
      "regex": "^/api/server\\-status(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/server\\-status(?:/)?$"
    },
    {
      "page": "/api/uploads",
      "regex": "^/api/uploads(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/uploads(?:/)?$"
    },
    {
      "page": "/discussions",
      "regex": "^/discussions(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/discussions(?:/)?$"
    },
    {
      "page": "/discussions/new",
      "regex": "^/discussions/new(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/discussions/new(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/features",
      "regex": "^/features(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/features(?:/)?$"
    },
    {
      "page": "/join",
      "regex": "^/join(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/join(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/news",
      "regex": "^/news(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/news(?:/)?$"
    },
    {
      "page": "/register",
      "regex": "^/register(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/register(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}