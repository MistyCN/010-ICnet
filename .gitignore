# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/out/
/.next/dev/
/.next/_events_*.json
/.next/standalone/.next/node_modules/**/build/**
!/.next/standalone/.next/node_modules/**/build/Release/
!/.next/standalone/.next/node_modules/**/build/Release/*.node
/.next/standalone/.next/node_modules/**/build/Release/test_extension.node
/.next/standalone/.next/node_modules/**/deps/
/.next/standalone/.next/node_modules/**/src/
/.next/standalone/.next/node_modules/**/binding.gyp
/.next/standalone/.next/node_modules/**/LICENSE
/.next/standalone/.next/node_modules/**/README.md

# production
/build

# local runtime data
/data/
*.db
*.sqlite
*.sqlite3
*.tar
*.tar.gz

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
