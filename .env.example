# Server address displayed to players and used by the status API
NEXT_PUBLIC_SERVER_IP=infcraft.mistycn.com
NEXT_PUBLIC_SERVER_PORT=25565

# Timeout for querying the server (in milliseconds, default 8000)
MC_STATUS_TIMEOUT_MS=12000

# Cache time-to-live in seconds (default 30)
MC_STATUS_CACHE_TTL_SECONDS=30

# Database configurations
DATABASE_URL="file:./dev.db"

# NextAuth configurations
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-secure-secret"

# Global bootstrap admin password for /admin.
# Use this only to grant OP to a registered user, then manage the site as that OP user.
GLOBAL_ADMIN_PASSWORD="replace-with-a-secure-admin-password"
