# Frontend display configurations
NEXT_PUBLIC_SERVER_IP=mc.example.com
NEXT_PUBLIC_SERVER_PORT=25565

# Backend query configurations (If not set, defaults to the NEXT_PUBLIC_ values above)
MC_SERVER_HOST=mc.example.com
MC_SERVER_PORT=25565

# Timeout for querying the server (in milliseconds, default 3000)
MC_STATUS_TIMEOUT_MS=3000

# Cache time-to-live in seconds (default 30)
MC_STATUS_CACHE_TTL_SECONDS=30
